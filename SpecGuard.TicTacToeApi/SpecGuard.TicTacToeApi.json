{
  "openapi": "3.1.1",
  "info": {
    "title": "SpecGuard.TicTacToeApi | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/board": {
      "get": {
        "tags": [
          "SpecGuard.TicTacToeApi"
        ],
        "operationId": "get-board",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoardStatus"
                }
              }
            }
          }
        }
      }
    },
    "/board/{row}/{column}": {
      "get": {
        "tags": [
          "SpecGuard.TicTacToeApi"
        ],
        "operationId": "get-square",
        "parameters": [
          {
            "name": "row",
            "in": "path",
            "required": true,
            "schema": {
              "maximum": 3,
              "minimum": 1,
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "column",
            "in": "path",
            "required": true,
            "schema": {
              "maximum": 3,
              "minimum": 1,
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Mark"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "SpecGuard.TicTacToeApi"
        ],
        "operationId": "put-square",
        "parameters": [
          {
            "name": "row",
            "in": "path",
            "required": true,
            "schema": {
              "maximum": 3,
              "minimum": 1,
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "column",
            "in": "path",
            "required": true,
            "schema": {
              "maximum": 3,
              "minimum": 1,
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Mark"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoardStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BoardStatus": {
        "required": [
          "winner",
          "board"
        ],
        "type": "object",
        "properties": {
          "winner": {
            "$ref": "#/components/schemas/Mark"
          },
          "board": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Mark"
              }
            }
          }
        }
      },
      "Mark": {
        "enum": [
          ".",
          "X",
          "O"
        ]
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "SpecGuard.TicTacToeApi"
    }
  ]
}